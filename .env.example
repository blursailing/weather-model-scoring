# BLUR Observation Collector — Environment Variables
# Copy to .env and fill in values:  cp .env.example .env

# MySQL connection (production / Oderland)
DB_HOST=localhost
DB_NAME=blurse_weather
DB_USER=blurse_wxcoll
DB_PASS=CHANGE_ME

# Optional: use SQLite for local development
# DB_BACKEND=sqlite
# DB_SQLITE_PATH=./data/observations.db

# MET Norway Frost API (register free at https://frost.met.no/auth/requestCredentials.html)
MET_NORWAY_CLIENT_ID=your-client-id-here

# SMHI — no key needed
# DMI  — no key needed (removed Dec 2025)
# FMI  — no key needed
